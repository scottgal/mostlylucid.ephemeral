<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet Package Metadata -->
        <PackageId>mostlylucid.ephemeral.complete</PackageId>
        <Authors>Scott Galloway</Authors>
        <Description>Meta-package that references all Mostlylucid.Ephemeral packages - bounded async execution with signals, atoms, and patterns. Install this single package to get everything.</Description>
        <PackageTags>async;parallel;concurrency;observability;signals;coordination;complete;bundle;metapackage</PackageTags>
        <PackageLicenseExpression>Unlicense</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReleaseNotes>$([System.IO.File]::ReadAllText("$(MSBuildProjectDirectory)/ReleaseNotes.txt"))</PackageReleaseNotes>
        <RepositoryUrl>https://github.com/scottgal/mostlylucid.atoms</RepositoryUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>2.3.0-alpha1</Version>

        <!-- Internal package version - update this when releasing -->
        <InternalPackageVersion>2.3.0</InternalPackageVersion>
    </PropertyGroup>

    <!-- Core packages (internal - use VersionOverride to bypass CPM) -->
    <ItemGroup>
        <PackageReference Include="mostlylucid.ephemeral" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="mostlylucid.ephemeral.logging" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="mostlylucid.ephemeral.attributes" VersionOverride="$(InternalPackageVersion)" />
    </ItemGroup>

    <!-- Atom packages (internal) -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Batching" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.BurstDetection" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.File" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.Postgres" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.Sqlite" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Echo" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.EntropyAnalysis" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Escalator" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.FixedWork" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.imagesharp" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.KeyedSequential" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Molecules" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.PriorityProcessor" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.ratelimit" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.RazorTemplate" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Retry" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.ScheduledTasks" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.SignalAware" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.SlidingCache" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Smtp" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.TimeSeriesAnomaly" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Volatile" VersionOverride="2.3.0-alpha1" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.WaveOrchestrator" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.windowsize" VersionOverride="$(InternalPackageVersion)" />
    </ItemGroup>

    <!-- Taxonomy packages (internal) -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Constrainer" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Coordinator" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Embedder" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Extractor" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Feedback" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Guard" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Proposer" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Ranker" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Renderer" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Retriever" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Sensor" VersionOverride="$(InternalPackageVersion)" />
    </ItemGroup>

    <!-- SQLite Single Writer (internal) -->
    <ItemGroup>
        <PackageReference Include="mostlylucid.ephemeral.sqlite.singlewriter" VersionOverride="$(InternalPackageVersion)" />
    </ItemGroup>

    <!-- Pattern packages (internal) -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.AdaptiveRate" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.AnomalyDetector" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.Backpressure" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.CircuitBreaker" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.ControlledFanOut" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.DynamicConcurrency" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.KeyedPriorityFanOut" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.LongWindowDemo" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.PersistentWindow" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.ReactiveFanOut" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.SignalCoordinatedReads" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.SignalingHttp" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.SignalLogWatcher" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.SignalReactionShowcase" VersionOverride="$(InternalPackageVersion)" />
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.Telemetry" VersionOverride="2.3.0-alpha1" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
        <None Include="icon.png" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
