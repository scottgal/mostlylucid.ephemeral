<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet Package Metadata -->
        <PackageId>mostlylucid.ephemeral.complete</PackageId>
        <Authors>Scott Galloway</Authors>
        <Description>Meta-package that references all Mostlylucid.Ephemeral packages - bounded async execution with signals, atoms, and patterns. Install this single package to get everything.</Description>
        <PackageTags>async;parallel;concurrency;observability;signals;coordination;complete;bundle;metapackage</PackageTags>
        <PackageLicenseExpression>Unlicense</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReleaseNotes>$([System.IO.File]::ReadAllText("$(MSBuildProjectDirectory)/ReleaseNotes.txt"))</PackageReleaseNotes>
        <RepositoryUrl>https://github.com/scottgal/mostlylucid.atoms</RepositoryUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>2.0.0</Version>
    </PropertyGroup>

    <!-- Core packages -->
    <ItemGroup>
        <PackageReference Include="mostlylucid.ephemeral" Version="2.0.0" />
        <PackageReference Include="mostlylucid.ephemeral.logging" Version="2.0.0" />
        <PackageReference Include="mostlylucid.ephemeral.attributes" Version="2.0.0" />
    </ItemGroup>

    <!-- Atom packages -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Batching" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.BurstDetection" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.File" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.Postgres" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Data.Sqlite" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Echo" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.EntropyAnalysis" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Escalator" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.FixedWork" Version="2.0.0" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.imagesharp" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.KeyedSequential" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Molecules" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.PriorityProcessor" Version="2.0.0" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.ratelimit" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.RazorTemplate" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Retry" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.ScheduledTasks" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.SignalAware" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.SlidingCache" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Smtp" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.TimeSeriesAnomaly" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Volatile" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.WaveOrchestrator" Version="2.0.0" />
        <PackageReference Include="mostlylucid.ephemeral.atoms.windowsize" Version="2.0.0" />
    </ItemGroup>

    <!-- Taxonomy packages -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Constrainer" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Coordinator" Version="2.0.0" />
