        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Guard" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Proposer" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Ranker" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Renderer" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Retriever" Version="2.0.0" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy.Sensor" Version="2.0.0" />
    </ItemGroup>

    <!-- SQLite Single Writer -->
    <ItemGroup>
        <PackageReference Include="mostlylucid.ephemeral.sqlite.singlewriter" Version="2.0.0" />
    </ItemGroup>

    <!-- Pattern packages -->
    <ItemGroup>
        <PackageReference Include="Mostlylucid.Ephemeral.Patterns.AdaptiveRate" Version="2.0.0" />
