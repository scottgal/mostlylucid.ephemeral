<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet Package Metadata -->
        <PackageId>mostlylucid.ephemeral.complete</PackageId>
        <Authors>Scott Galloway</Authors>
        <Description>Meta-package that references all Mostlylucid.Ephemeral packages - bounded async execution with signals, atoms, and patterns. Install this single package to get everything.</Description>
        <PackageTags>async;parallel;concurrency;observability;signals;coordination;complete;bundle;metapackage</PackageTags>
        <PackageLicenseExpression>Unlicense</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReleaseNotes>$([System.IO.File]::ReadAllText("$(MSBuildProjectDirectory)/ReleaseNotes.txt"))</PackageReleaseNotes>
        <RepositoryUrl>https://github.com/scottgal/mostlylucid.atoms</RepositoryUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>2.9.0</Version>
    </PropertyGroup>

    <!-- Family packages composed by project reference; pack turns each into a
         package dependency pinned to this bundle's release version. -->
    <ItemGroup>
        <ProjectReference Include="..\mostlylucid.ephemeral\mostlylucid.ephemeral.csproj" />
        <ProjectReference Include="..\mostlylucid.ephemeral.logging\mostlylucid.ephemeral.logging.csproj" />
        <ProjectReference Include="..\mostlylucid.ephemeral.attributes\mostlylucid.ephemeral.attributes.csproj" />
    </ItemGroup>

