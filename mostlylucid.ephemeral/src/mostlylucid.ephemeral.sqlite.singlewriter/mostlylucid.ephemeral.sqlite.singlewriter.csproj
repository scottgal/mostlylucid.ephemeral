<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet Package Metadata -->
        <PackageId>mostlylucid.ephemeral.sqlite.singlewriter</PackageId>
        <Authors>Scott Galloway</Authors>
        <Description>Safe SQLite single-writer access with mini CQRS pattern. Keyed by connection string with cached read access and serialized writes.</Description>
        <PackageTags>sqlite;cqrs;single-writer;cache;async;concurrency</PackageTags>
        <PackageLicenseExpression>Unlicense</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReleaseNotes>$([System.IO.File]::ReadAllText("$(MSBuildProjectDirectory)/ReleaseNotes.txt"))</PackageReleaseNotes>
        <RepositoryUrl>https://github.com/scottgal/mostlylucid.atoms</RepositoryUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>2.9.0</Version>
        <!-- Lock AssemblyVersion to match what's been shipped to NuGet (2.0.0.0).
             Without an explicit value MSBuild derives AssemblyVersion from the
             package Version (e.g. 2.6.4.0), which doesn't match the binary
             ALREADY published as 2.0.0.0 — downstream consumers compiled locally
             then end up with a runtime reference at 2.6.4.0 that fails to load
             against the cached NuGet 2.0.0.0 DLL. Locking the assembly version
             keeps binary compatibility across patch / minor releases. -->
        <AssemblyVersion>2.0.0.0</AssemblyVersion>
        <FileVersion>$(Version).0</FileVersion>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\mostlylucid.ephemeral\mostlylucid.ephemeral.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Data.Sqlite" />
        <PackageReference Include="Microsoft.Extensions.Caching.Memory" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
        <None Include="icon.png" Pack="true" PackagePath="\"/>
    </ItemGroup>

</Project>
